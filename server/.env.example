# 数据库
DATABASE_URL="postgresql://salary_admin:your_password@localhost:5432/salary_db"

# JWT 密钥（生产环境请替换为随机字符串）
JWT_SECRET="change-me-to-a-random-secret-string"
JWT_REFRESH_SECRET="change-me-to-another-random-string"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"

# 服务器
PORT=3000
NODE_ENV=development

# CORS（允许的前端地址）
CORS_ORIGIN="http://localhost:5173"

# 初始管理员（启动时自动确保账号可用）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-now"
