# ============================================
# 薪酬数据后台管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env.local (开发) 或 .env.production (生产) 并修改对应值
#
# 文件优先级（从高到低）:
#   .env.[mode].local  >  .env.[mode]  >  .env.local  >  .env
#
# 注意: Vite 只暴露以 VITE_ 开头的变量给客户端代码
# ============================================

# ---------- 应用基础配置 ----------
# 应用标题（显示在浏览器标签页）
VITE_APP_TITLE=薪酬数据后台管理系统

# 应用版本号
VITE_APP_VERSION=1.0.0

# ---------- 认证配置 ----------
# 当前版本使用前端 mock 认证 (admin/admin)
# 如需对接后端 API，配置以下变量并修改 src/hooks/useAuth.ts
# VITE_AUTH_API_URL=https://api.example.com/auth/login

# ---------- API 配置（预留）----------
# 当前版本数据存储在 localStorage，无后端 API
# 如需对接后端，配置 API 基础地址
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_TIMEOUT=30000

# ---------- 路由配置 ----------
# 路由基础路径，与 vite.config.ts 中的 base 保持一致
# 部署到根路径用 '/'，部署到子目录用 '/sub-path/'
VITE_BASE_PATH=./

# ---------- 功能开关 ----------
# 是否启用分析引擎自动洞察
VITE_ENABLE_ANALYSIS=true
