# ===== Docker Compose 环境变量 =====
# 复制此文件为 .env 并修改

# 数据库
DB_USER=salary_admin
DB_PASSWORD=change-me-in-production

# JWT 密钥（用 openssl rand -hex 32 生成替换）
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random

# 前端访问端口
# 只用于公司内网时，建议改为服务器内网 IP，例如 192.168.1.10
CLIENT_BIND=0.0.0.0
CLIENT_PORT=80

# 允许的前端域名（改为你的服务器 IP 或域名）
CORS_ORIGIN=http://localhost

# 初始管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
